@using DevHub.Models
@using DevHub.Services
@inject ISnackbar Snackbar

<MudDrawer @bind-Open="_open"
           Anchor="Anchor.Right"
           Variant="DrawerVariant.Temporary"
           Width="600px"
           Elevation="4"
           Style="display:flex; flex-direction:column">

    @* ── Header ── *@
    <MudDrawerHeader Style="padding:6px 12px; flex-shrink:0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Style="width:100%">
            <MudIcon Icon="@Icons.Material.Filled.Terminal" Color="Color.Primary" Size="Size.Small" />
            <MudText Typo="Typo.subtitle1" Class="ml-1"
                     Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1">
                @_repo?.Name
            </MudText>
            <MudTooltip Text="@(_compact ? "Mostrar texto" : "Solo iconos")">
                <MudIconButton Icon="@(_compact ? Icons.Material.Filled.TextFields : Icons.Material.Filled.GridView)"
                               Size="Size.Small"
                               OnClick="() => _compact = !_compact"
                               aria-label="Alternar modo compacto" />
            </MudTooltip>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small"
                           OnClick="Close"
                           aria-label="Cerrar" />
        </MudStack>
    </MudDrawerHeader>

    @* ── Body: commands + interactive console ── *@
    <div style="display:flex; flex-direction:column; flex:1; min-height:0; overflow:hidden">

        @* Commands section (max 260px, scrolls internally) *@
        <div style="flex-shrink:0; max-height:260px; overflow-y:auto; padding:6px 12px">

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2" />
            }
            else
            {
                @* Detectados *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Detectados</MudText>
                    <MudSpacer />
                    <MudTooltip Text="Volver a escanear y restaurar todos">
                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                       Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="RescanAsync"
                                       aria-label="Rescanear" />
                    </MudTooltip>
                </MudStack>

                @if (_autoCommands.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-2">
                        No se detectaron comandos.
                    </MudText>
                }
                else
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-2">
                        @foreach (var cmd in _autoCommands)
                        {
                            <MudTooltip Text="@cmd.Command" Placement="Placement.Bottom">
                                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="margin-bottom:4px">
                                    <MudButton Color="Color.Primary"
                                               StartIcon="@GetIcon(cmd)"
                                               OnClick="() => InjectCommand(cmd.Command)">
                                        @if (!_compact)
                                        {
                                            @cmd.Name
                                        }
                                    </MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   Color="Color.Default"
                                                   OnClick="() => HideAutoCommandAsync(cmd)"
                                                   aria-label="Ocultar" />
                                </MudButtonGroup>
                            </MudTooltip>
                        }
                    </MudStack>
                }

                <MudDivider Class="my-1" />

                @* Personalizados *@
                <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-1 mt-1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Personalizados</MudText>
                    <MudSpacer />
                    <MudTooltip Text="Añadir comando" Placement="Placement.Left">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircleOutline"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="OpenAddCommandDialogAsync"
                                       aria-label="Añadir comando" />
                    </MudTooltip>
                </MudStack>

                @if (_customCommands.Count == 0)
                {
                    <MudText Typo="Typo.caption" Color="Color.Default" Class="mb-1">
                        Sin comandos personalizados.
                    </MudText>
                }
                else
                {
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-1">
                        @foreach (var custom in _customCommands)
                        {
                            <MudTooltip Text="@custom.Command" Placement="Placement.Bottom">
                                <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Style="margin-bottom:4px">
                                    <MudButton Color="Color.Secondary"
                                               StartIcon="@GetCustomIcon(custom)"
                                               OnClick="() => InjectCommand(custom.Command)">
                                        @if (!_compact)
                                        {
                                            @custom.Name
                                        }
                                    </MudButton>
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                   Size="Size.Small"
                                                   Color="Color.Default"
                                                   OnClick="() => DeleteCustomAsync(custom.Id)"
                                                   aria-label="Eliminar" />
                                </MudButtonGroup>
                            </MudTooltip>
                        }
                    </MudStack>
                }
            }
        </div>

        <MudDivider />

        @* Interactive console — fills remaining height *@
        <div style="flex:1; min-height:0">
            <InteractiveConsole @ref="_console" RepoPath="@_repo?.Path" />
        </div>

    </div>

</MudDrawer>
