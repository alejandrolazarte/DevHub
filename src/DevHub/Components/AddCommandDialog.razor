<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Class="mr-2" />
            Nuevo comando
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Class="pt-1">
            <MudTextField T="string"
                          @bind-Value="_name"
                          Label="Nombre"
                          Placeholder="Ej: Migrate DB"
                          Variant="Variant.Outlined"
                          AutoFocus="true" />
            <MudTextField T="string"
                          @bind-Value="_command"
                          Label="Comando"
                          Placeholder="Ej: dotnet run --project src/API"
                          Variant="Variant.Outlined"
                          Lines="2" />
            <div>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Icono</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    @foreach (var opt in AddCommandDialog.IconOptions)
                    {
                        <MudTooltip Text="@opt.Label" Placement="Placement.Top">
                            <MudIconButton Icon="@opt.Icon"
                                           Color="@(_icon == opt.Key ? Color.Primary : Color.Default)"
                                           Variant="@(_icon == opt.Key ? Variant.Filled : Variant.Outlined)"
                                           Size="Size.Small"
                                           OnClick="() => _icon = opt.Key" />
                        </MudTooltip>
                    }
                </MudStack>
            </div>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || string.IsNullOrWhiteSpace(_command))"
                   OnClick="Confirm">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>
