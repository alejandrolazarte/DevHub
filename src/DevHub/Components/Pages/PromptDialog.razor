<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Value"
                      Label="@Label"
                      HelperText="@HelperText"
                      Variant="Variant.Outlined"
                      Immediate="true"
                      OnKeyDown="OnKeyDown" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@string.IsNullOrWhiteSpace(Value)">OK</MudButton>
    </DialogActions>
</MudDialog>