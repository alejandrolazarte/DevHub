@page "/secret-profiles"
@rendermode InteractiveServer
@using DevHub.Services.SecretProfiles
@using BlazorMonaco.Editor
@inject SecretProfileService ProfileService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Secret Profiles</PageTitle>

<MudPaper Class="pa-3 mb-3" Elevation="1">
    <MudStack Row="true" AlignItems="AlignItems.Center">
        <MudText Typo="Typo.h6" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Class="mr-1" /> Secret Profiles
        </MudText>
        <MudText Typo="Typo.caption" Color="Color.Default" Class="ml-2">
            Cambia entre perfiles de <code>secrets.json</code> sin comentar/descomentar
        </MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Refresh" OnClick="ReloadAsync" aria-label="refresh" />
    </MudStack>
</MudPaper>

@if (_services.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        Ningún servicio configurado en <code>SecretProfiles.Services</code>.
    </MudAlert>
}
else
{
    <MudStack Spacing="3">
        @foreach (var svc in _services)
        {
            var state = _state.GetValueOrDefault(svc.Name);
            <MudCard Elevation="2">
                <MudCardHeader Style="@(state?.Active.IsProd == true ? "background: #4a0000;" : "")">
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                            <MudText Typo="Typo.h6">@svc.Name</MudText>
                            @if (state is null)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">cargando…</MudChip>
                            }
                            else if (!state.Active.LiveSecretsExists)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.HelpOutline">SIN SECRETS</MudChip>
                            }
                            else if (state.Active.IsProd)
                            {
                                <MudChip T="string" Size="Size.Large" Color="Color.Error" Icon="@Icons.Material.Filled.Warning" Style="font-size: 1.1em; font-weight: 700;">
                                    PROD · @state.Active.MatchedProfileName
                                </MudChip>
                            }
                            else if (state.Active.MatchedProfileName is not null)
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                    DEV · @state.Active.MatchedProfileName
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Medium" Color="Color.Warning" Icon="@Icons.Material.Filled.Edit">DIRTY (editado a mano)</MudChip>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Default">@svc.UserSecretsId</MudText>
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton StartIcon="@Icons.Material.Filled.CameraAlt"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Disabled="@(state is null || !state.Active.LiveSecretsExists)"
                                   OnClick="@(() => CaptureAsync(svc.Name))">
                            Capturar actual como…
                        </MudButton>
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       OnClick="@(() => ViewLiveAsync(svc.Name))"
                                       Disabled="@(state is null || !state.Active.LiveSecretsExists)"
                                       aria-label="ver secrets.json actual" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (state is null)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                    }
                    else if (state.Profiles.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            No hay perfiles todavía. Usa <b>Capturar actual como…</b> para crear el primero.
                        </MudAlert>
                    }
                    else
                    {
                        <MudTable Items="state.Profiles" Dense="true" Hover="true" Bordered="false">
                            <HeaderContent>
                                <MudTh>Perfil</MudTh>
                                <MudTh>Tamaño</MudTh>
                                <MudTh>Modificado</MudTh>
                                <MudTh Style="width: 420px; text-align: right;">Acciones</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    @if (context.IsProd)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Class="mr-1">PROD</MudChip>
                                    }
                                    <b>@context.Name</b>
                                    @if (state.Active.MatchedProfileName == context.Name)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-1">activo</MudChip>
                                    }
                                </MudTd>
                                <MudTd>@FormatSize(context.SizeBytes)</MudTd>
                                <MudTd>@context.ModifiedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                                <MudTd Style="text-align: right;">
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Filled"
                                               Color="@(context.IsProd ? Color.Error : Color.Primary)"
                                               StartIcon="@Icons.Material.Filled.PlayArrow"
                                               Disabled="@(state.Active.MatchedProfileName == context.Name)"
                                               OnClick="@(() => ApplyAsync(svc.Name, context))">
                                        Aplicar
                                    </MudButton>
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Visibility"
                                                   OnClick="@(() => ViewProfileAsync(svc.Name, context.Name))"
                                                   aria-label="ver" />
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.CompareArrows"
                                                   Disabled="@(!state.Active.LiveSecretsExists)"
                                                   OnClick="@(() => DiffProfileAsync(svc.Name, context.Name))"
                                                   aria-label="diff" />
                                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Default"
                                                   Disabled="@(state.Active.MatchedProfileName == context.Name)"
                                                   OnClick="@(() => DeleteAsync(svc.Name, context.Name))"
                                                   aria-label="borrar" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        }
    </MudStack>
}